# Python runtime that already has markitdown installed
MARKITDOWN_PYTHON=~/.venvs/markitdown/bin/python

# Vision / OCR settings
MARKITDOWN_LLM_PROVIDER=auto
MARKITDOWN_LLM_MODEL=gpt-4o
MARKITDOWN_LLM_PROMPT=
MARKITDOWN_ENABLE_PLUGINS=0
MARKITDOWN_ENABLE_OCR=0

# OpenAI-compatible provider
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=

# Azure OpenAI provider
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
